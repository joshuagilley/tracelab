# Copy to .env for local API (do not commit secrets).
# ── MongoDB ─────────────────────────────────────────────────────────
# No quotes needed unless the value contains spaces. If the password has @ # : / ? use URL-encoding in the URI.
MONGO_DB_URI=mongodb+srv://user:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=tracelab
USERS_COLLECTION=Users

# ── GitHub OAuth App (Settings → Developer settings → OAuth Apps) ───
GITHUB_CLIENT_ID=Ov23li0KsGVI9Q4EIf4o
GITHUB_CLIENT_SECRET=1a9d99b4e6502a0f01b6d2afd8217d4d9649d868
# MUST match one "Authorization callback URL" in the GitHub OAuth app byte-for-byte
# (scheme, host, port, path — no trailing slash). GitHub shows "redirect_uri is not associated"
# if this differs from what you registered.
# Local + Vite: use :5173 so the browser and OAuth callback share the same origin (proxy → API).
OAUTH_CALLBACK_URL=http://localhost:5173/api/auth/github/callback
# Where users land after login (your SPA origin)
FRONTEND_ORIGIN=http://localhost:5173

# Random long secret for signing session JWTs (e.g. openssl rand -hex 32)
AUTH_JWT_SECRET=lb2uA4JtaKHPlxjRYWif0yTNyS6lE0oP4Vl500OGEow

# If the SPA and API are on different hosts (e.g. two Cloud Run URLs), set true so cookies use SameSite=None; Secure.
AUTH_COOKIE_CROSS_SITE=false
